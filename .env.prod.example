# Production self-host config for docker-compose.prod.yml.
# Copy to `.env` (which is gitignored) and fill in real values:
#   cp .env.prod.example .env

# Domain Caddy obtains HTTPS for. Point its DNS A/AAAA record at this server
# BEFORE first boot. This is your backend API host, e.g. api.plugpulse.app.
DOMAIN=api.example.com

# PostgreSQL credentials. CHANGE THE PASSWORD — it guards your database.
POSTGRES_USER=plugpulse
POSTGRES_PASSWORD=change-me-to-a-long-random-secret
POSTGRES_DB=plugpulse

# Open Charge Map API key (optional; free to obtain). Leave blank to omit.
OCM_API_KEY=

# Comma-separated browser origins allowed to call the API via CORS.
# Set this to your deployed frontend origin(s) — your Vercel URL and/or domain.
# Example: https://plugpulse.vercel.app,https://plugpulse.app
CORS_ALLOW_ORIGINS=

# --- Authentik (self-hosted OIDC identity provider) ---
# Subdomain Caddy obtains HTTPS for and routes to Authentik (point its DNS here).
AUTH_DOMAIN=auth.example.com
# Generate strong values, e.g.: openssl rand -base64 48
AUTHENTIK_SECRET_KEY=change-me-to-a-long-random-secret
AUTHENTIK_PG_PASS=change-me-to-a-strong-db-password
# Optionally pin the Authentik image (default: 2024.12)
# AUTHENTIK_TAG=2024.12

# --- OIDC verification (backend) ---
# Fill these AFTER creating the PlugPulse OAuth2/OIDC provider in Authentik
# (DEPLOYMENT.md). Issuer + JWKS use your AUTH_DOMAIN and the app slug; audience
# is the provider's Client ID.
#   OIDC_ISSUER=https://auth.example.com/application/o/plugpulse/
#   OIDC_JWKS_URL=https://auth.example.com/application/o/plugpulse/jwks/
#   OIDC_AUDIENCE=<client-id-from-authentik>
OIDC_ISSUER=
OIDC_JWKS_URL=
OIDC_AUDIENCE=
