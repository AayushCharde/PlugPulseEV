# Base URL of the PlugPulse backend API (no trailing slash).
# Local dev: the FastAPI server from `docker compose up` or `uvicorn`.
PUBLIC_API_BASE_URL=http://localhost:8000

# CORS: the backend only sends CORS headers for origins in its CORS_ALLOW_ORIGINS
# env var. For local dev, start the backend with:
#   CORS_ALLOW_ORIGINS=http://localhost:5173
# Otherwise the browser blocks the /stations reads (the API still returns 200).

# --- Authentication (Auth.js -> Authentik); server-only, never shipped to the browser ---
# Generate a secret: openssl rand -base64 33
AUTH_SECRET=
# From the OAuth2/OIDC provider you create in Authentik (see DEPLOYMENT.md):
AUTH_AUTHENTIK_ISSUER=http://localhost:9000/application/o/plugpulse/
AUTH_AUTHENTIK_ID=
AUTH_AUTHENTIK_SECRET=
