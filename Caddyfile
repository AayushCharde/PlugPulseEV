# Caddy reverse proxy for the PlugPulse backend.
# $DOMAIN comes from the environment (see .env.prod.example). Caddy obtains and
# renews a Let's Encrypt certificate automatically — no manual TLS setup.

{$DOMAIN} {
	encode gzip
	reverse_proxy backend:8000
}

# Authentik (OIDC identity provider) on its own subdomain.
{$AUTH_DOMAIN} {
	encode gzip
	reverse_proxy authentik-server:9000
}
